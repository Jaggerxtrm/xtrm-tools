{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git config pull.ff only",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node /home/dawid/projects/specialists/hooks/specialists-session-start.mjs"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node /home/dawid/projects/specialists/hooks/specialists-complete.mjs"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "xtrm-tools@xtrm-tools": true
  },
  "extraKnownMarketplaces": {
    "xtrm-tools": {
      "source": {
        "source": "directory",
        "path": "/home/dawid/projects/xtrm-tools"
      }
    },
    "claude-plugins-official": {
      "source": {
        "source": "git",
        "url": "https://github.com/anthropics/claude-plugins-official.git"
      }
    }
  },
  "UserPromptSubmit": [
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "node .specialists/default/hooks/specialists-complete.mjs"
        }
      ]
    },
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "node .claude/hooks/specialists-complete.mjs"
        }
      ]
    }
  ],
  "SessionStart": [
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "node .specialists/default/hooks/specialists-session-start.mjs"
        }
      ]
    },
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "node .claude/hooks/specialists-session-start.mjs"
        }
      ]
    }
  ]
}
