{
  "name": "xtrm-tools",
  "version": "0.5.34",
  "description": "Claude Code tools installer (skills, hooks, MCP servers)",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "cli"
  ],
  "bin": {
    "xtrm": "cli/dist/index.cjs",
    "xt": "cli/dist/index.cjs"
  },
  "files": [
    "README.md",
    "CHANGELOG.md",
    "cli/dist",
    "cli/package.json",
    "config",
    "hooks",
    "skills",
    "project-skills",
    ".claude-plugin",
    "plugins",
    "!**/__pycache__/**",
    "!**/*.pyc",
    "!project-skills/service-skills-set/.claude/skills/using-service-skills/scripts/test_*.py",
    "!skills/documenting/tests/**"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jaggerxtrm/xtrm-tools.git"
  },
  "homepage": "https://github.com/Jaggerxtrm/xtrm-tools#readme",
  "bugs": {
    "url": "https://github.com/Jaggerxtrm/xtrm-tools/issues"
  },
  "scripts": {
    "sync:cli-version": "node scripts/sync-cli-version.mjs",
    "compile-policies": "node scripts/compile-policies.mjs",
    "check-policies": "node scripts/compile-policies.mjs --check",
    "check-pi": "node scripts/compile-policies.mjs --check-pi",
    "prebuild": "npm run sync:cli-version",
    "build": "npm run build --workspace cli",
    "typecheck": "npm run typecheck --workspace cli",
    "start": "node cli/dist/index.cjs",
    "lint": "echo 'No linting configured'",
    "test": "npm test --workspace cli",
    "version": "npm run sync:cli-version && git add cli/package.json",
    "prepack": "node scripts/prepack-plugin.mjs",
    "postpack": "node scripts/postpack-plugin.mjs",
    "prepublishOnly": "npm run sync:cli-version && npm run build",
    "release": "npm publish --tag latest"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "comment-json": "^4.2.3",
    "conf": "^15.1.0",
    "dotenv": "^17.3.1",
    "fs-extra": "^11.2.0",
    "kleur": "^4.1.5",
    "prompts": "^2.4.2",
    "xtrm-tools": "^2.0.2"
  },
  "pi": {
    "extensions": [
      "./config/pi/extensions"
    ],
    "packages": [
      "npm:pi-dex",
      "npm:pi-gitnexus",
      "npm:pi-serena-tools",
      "npm:@zenobius/pi-worktrees",
      "npm:@robhowley/pi-structured-return",
      "npm:@aliou/pi-guardrails"
    ]
  }
}
