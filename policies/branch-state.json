{
  "id": "branch-state",
  "description": "Inject current git branch and beads claim state into every user prompt turn.",
  "version": "1",
  "runtime": "claude",
  "order": 30,
  "claude": {
    "hooks": [
      {
        "event": "UserPromptSubmit",
        "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/branch-state.mjs",
        "timeout": 3000
      }
    ]
  }
}
