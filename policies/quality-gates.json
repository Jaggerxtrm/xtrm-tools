{
  "id": "quality-gates",
  "description": "Run project quality checks (lint/typecheck) after mutating file edits. Invokes quality-check hooks for TS/JS and Python files.",
  "version": "1",
  "runtime": "both",
  "order": 30,
  "claude": {
    "hooks": [
      {
        "event": "PostToolUse",
        "matcher": "$WRITE_TOOLS",
        "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/quality-check.cjs",
        "timeout": 30000
      },
      {
        "event": "PostToolUse",
        "matcher": "$WRITE_TOOLS",
        "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/quality-check.py",
        "timeout": 30000
      }
    ]
  },
  "pi": {
    "extension": "config/pi/extensions/quality-gates.ts",
    "events": ["tool_result"]
  }
}
