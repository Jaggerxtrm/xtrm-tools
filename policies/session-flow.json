{
  "id": "session-flow",
  "description": "Claim sync (auto-commit on bd close), stop gate (blocks agent stop with unclosed in_progress claim), xt end reminder when session ends in a worktree.",
  "version": "1",
  "runtime": "both",
  "order": 19,
  "claude": {
    "hooks": [
      {
        "event": "PostToolUse",
        "matcher": "Bash|execute_shell_command|bash",
        "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/beads-claim-sync.mjs",
        "timeout": 5000
      },
      {
        "event": "Stop",
        "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/beads-stop-gate.mjs",
        "timeout": 5000
      }
    ]
  },
  "pi": {
    "extension": "config/pi/extensions/session-flow.ts",
    "events": ["tool_result", "agent_end"]
  }
}
