{
  "id": "using-xtrm",
  "description": "Inject using-xtrm session operating manual into system prompt at session start.",
  "version": "1",
  "runtime": "both",
  "order": 5,
  "claude": {
    "hooks": [
      {
        "event": "SessionStart",
        "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/using-xtrm-reminder.mjs"
      }
    ]
  },
  "pi": {
    "extension": "packages/pi-extensions/extensions/xtrm-loader/index.ts",
    "events": ["session_start", "before_agent_start"]
  }
}
