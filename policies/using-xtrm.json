{
  "id": "using-xtrm",
  "description": "Inject using-xtrm session operating manual into system prompt at session start.",
  "version": "1",
  "runtime": "claude",
  "order": 5,
  "claude": {
    "hooks": [
      {
        "event": "SessionStart",
        "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/using-xtrm-reminder.mjs"
      }
    ]
  }
}
