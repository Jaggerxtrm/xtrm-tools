{
  "id": "worktree-boundary",
  "description": "Block file edits outside the active worktree root when running inside .xtrm/worktrees/<name>.",
  "version": "1",
  "runtime": "claude",
  "order": 15,
  "claude": {
    "hooks": [
      {
        "event": "PreToolUse",
        "matcher": "$WRITE_TOOLS",
        "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/worktree-boundary.mjs",
        "timeout": 2000
      }
    ]
  }
}
