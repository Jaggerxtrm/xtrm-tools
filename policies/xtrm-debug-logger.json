{
  "id": "xtrm-debug-logger",
  "description": "Emit structured xtrm debug events for session start and all tool calls.",
  "version": "1",
  "runtime": "claude",
  "order": 45,
  "claude": {
    "hooks": [
      {
        "event": "SessionStart",
        "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/xtrm-session-logger.mjs",
        "timeout": 3000
      },
      {
        "event": "PostToolUse",
        "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/xtrm-tool-logger.mjs",
        "timeout": 3000
      }
    ]
  }
}
